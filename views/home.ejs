    <div class="text-center mt-4">
        <img src="https://hipcamp-res.cloudinary.com/f_auto,c_limit,w_1280,q_auto:eco/homepage/W15-2024/W15-USA-BEST-OF-HEADER.png"
             alt="Camping image" class="img-fluid rounded">
    </div>
</div>

<div class="container my-5">
    <!-- Heading Section -->
    <div class="text-center mb-5">
        <h2 class="fw-bold">Hipcamp has the perfect site to match your camping style.</h2>
    </div>

    <!-- Feature Cards Section -->
    <div class="row text-center">
        <!-- Card 1 -->
        <div class="col-md-4 mb-4">
            <div class="card border-0">
                <img src="/images/image_2.png" class="rounded-circle mx-auto mb-3" alt="Camping Tent" style="width: 80%; height: auto;">
                <div class="card-body">
                    <h5 class="card-title fw-bold">Camp your way.</h5>
                    <p class="card-text text-muted">No matter how you camp—in a tent, van or rig—with kids or your pup, we got you.</p>
                </div>
            </div>
        </div>
        <!-- Card 2 -->
        <div class="col-md-4 mb-4">
            <div class="card border-0">
                <img src="/images/image_3.png" class="rounded-circle mx-auto mb-3" alt="Camping Truck" style="width: 80%; height: auto;">
                <div class="card-body">
                    <h5 class="card-title fw-bold">Only on Hipcamp.</h5>
                    <p class="card-text text-muted">Explore our collection of over 120,000 sites you won’t find anywhere else.</p>
                </div>
            </div>
        </div>
        <!-- Card 3 -->
        <div class="col-md-4 mb-4">
            <div class="card border-0">
                <img src="/images/image_4.png" class="rounded-circle mx-auto mb-3" alt="Outdoor Experience" style="width: 80%; height: auto;">
                <div class="card-body">
                    <h5 class="card-title fw-bold">Find yourself outside.</h5>
                    <p class="card-text text-muted">Browse our comprehensive maps, read real reviews, and book direct with Hipcamp.</p>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="container-fluid px-0" style="margin-bottom: 5em;">
    <div class="position-relative">
        <img src="/images/image_1.webp" 
             alt="Hosting with Hipcamp" class="img-fluid w-100" style="max-height: 500px; object-fit: cover;">
        
        <div class="position-absolute top-50 start-0 translate-middle-y ms-4 p-4" style="max-width: 300px;">
            <div class="card bg-success text-white rounded-3 shadow">
                <div class="card-body">
                    <h5 class="card-title fw-bold">Own land? Earn money hosting with Hipcamp.</h5>
                    <p class="card-text">Host our community of good-natured campers and RV travelers at your property or campground business.</p>
                    <a href="/campgrounds/new" class="btn btn-light text-success fw-bold">Start hosting</a>
                </div>
            </div>
        </div>
    </div>
</div>
